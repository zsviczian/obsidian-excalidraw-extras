{
  "name": "@zsviczian/excalidraw-extras-api",
  "version": "0.0.11",
  "description": "API interfaces for Obsidian Excalidraw Extras",
  "main": "api/index.js",
  "types": "api/api/index.d.ts",
  "files": [
    "api/**/*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "rollup -c -w",
    "build": "tsc -noEmit -skipLibCheck && rollup -c --configProduction",
    "build:api": "shx rm -rf ./api && tsc -p tsconfig.api.json && shx touch ./api/index.js",
    "prepublishOnly": "npm run build:api",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint .",
    "lint:fix": "npx prettier --write \"src/**/*.{ts,tsx}\" && eslint --max-warnings=0 --ext .ts,.tsx ./src --fix"
  },
  "keywords": [],
  "license": "0-BSD",
  "dependencies": {
    "mathjax-full": "^3.2.2",
    "nanoid": "^5.1.11",
    "@excalidraw/mermaid-to-excalidraw": "2.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^22.19.20",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "obsidian": "1.8.7",
    "prettier": "^3.8.3",
    "rollup": "^4.40.2",
    "rollup-plugin-copy": "^3.5.0",
    "shx": "^0.4.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "nanoid": "^5.1.11"
  }
}