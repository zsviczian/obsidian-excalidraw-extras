{
"name": "@zsviczian/excalidraw-extras-api",
"version": "1.0.0",
"description": "Companion Obsidian plugin and typed API for Excalidraw Extras",
"main": "main.js",
"type": "module",
"types": "api/index.d.ts",
"files": [
"api/**/*",
"README.md",
"LICENSE"
],
"publishConfig": {
"access": "public"
},
"scripts": {
"dev": "rollup -c -w",
"build": "tsc -noEmit -skipLibCheck && rollup -c --configProduction",
"build:api": "tsc -p tsconfig.api.json",
"version": "node version-bump.mjs && git add manifest.json versions.json",
"lint": "eslint .",
"lint:fix": "eslint --max-warnings=0 --ext .ts,.tsx ./src --fix"
},
"keywords": [],
"license": "0-BSD",
"dependencies": {
"mathjax-full": "^3.2.2"
},
"devDependencies": {
"@eslint/js": "^9.39.4",
"@rollup/plugin-commonjs": "^28.0.6",
"@rollup/plugin-node-resolve": "^16.0.1",
"@rollup/plugin-terser": "^0.4.4",
"@rollup/plugin-typescript": "^12.1.4",
"@types/node": "^22.15.17",
"eslint": "^9.39.4",
"eslint-plugin-obsidianmd": "^0.3.0",
"globals": "^17.6.0",
"jiti": "^2.6.1",
"obsidian": "1.8.7",
"rollup": "^4.40.2",
"tslib": "^2.8.1",
"typescript": "^5.8.3",
"typescript-eslint": "^8.59.1"
}
}
